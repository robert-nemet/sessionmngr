<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-user-usage-table" author="session-manager">
        <createTable tableName="user_usage">
            <column name="user_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_user_usage_user" references="users(id)" deleteCascade="true"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="summaries_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="user_usage" columnNames="user_id, date" constraintName="pk_user_usage"/>
    </changeSet>

</databaseChangeLog>
